{
	"name": "ptlen",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "cross-env NODE_ENV=development tsx node_modules/@rspack/cli/bin/rspack serve",
		"build": "tsc -b && cross-env NODE_ENV=production tsx node_modules/@rspack/cli/bin/rspack build",
		"doc": "typedoc",
		"lint": "eslint .",
		"preview": "cross-env NODE_ENV=production rspack serve",
		"test": "jest",
		"backend": "tsx watch server.ts",
		"proto:gen": "node -e \"require('fs').mkdirSync('./src/utils/api/coordinate/generated',{recursive:true})\" && protoc -I=./src/utils/api/coordinate/proto ./src/utils/api/coordinate/proto/*.proto --js_out=import_style=commonjs:./src/utils/api/coordinate/generated --grpc-web_out=import_style=commonjs,mode=grpcwebtext:./src/utils/api/coordinate/generated"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"@types/ol": "^7.0.0",
		"clsx": "^2.1.0",
		"dotenv": "^17.3.1",
		"fastify": "^5.7.4",
		"framer-motion": "^12.29.2",
		"google-protobuf": "^4.0.1",
		"grpc-web": "^2.0.2",
		"lucide-react": "^0.563.0",
		"mysql2": "^3.16.3",
		"ol": "^10.7.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^2.2.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@rspack/cli": "^1.1.7",
		"@rspack/core": "^1.1.7",
		"@rspack/plugin-react-refresh": "^1.0.0",
		"@tailwindcss/postcss": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/google-protobuf": "^3.15.12",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.10.1",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.5",
		"autoprefixer": "^10.4.23",
		"cross-env": "^7.0.3",
		"eslint": "^9.39.1",
		"eslint-plugin-jsdoc": "^62.5.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"postcss": "^8.5.6",
		"postcss-loader": "^8.2.0",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.1.18",
		"ts-jest": "^29.4.6",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.16",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.46.4"
	}
}